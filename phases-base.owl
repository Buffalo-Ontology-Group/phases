        <rdfs:label xml:lang="en">psychological construct information content entity</rdfs:label>
        <skos:prefLabel xml:lang="en">psychological construct</skos:prefLabel>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PHASES_0000009 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PHASES_0000009">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PHASES_0000008"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-6906-5548"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0002-1118-1738"/>
        <terms:contributor rdf:resource="https://orcid.org/0009-0002-7282-0836"/>
        <terms:created>2025-06-14T22:20:08Z</terms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/PHASES_0002010"/>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/PHASES_0002012"/>
        <rdfs:label xml:lang="en">psychoanalytic psychological identity construct information content entity</rdfs:label>
        <skos:definition xml:lang="en">A psychological construct in which it is hypothesized that human consciousness consists of the id, ego, and superego.</skos:definition>
        <skos:prefLabel>psychoanalytic psychological identity construct</skos:prefLabel>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PHASES_0000010 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PHASES_0000010">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PHASES_0000036"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-6906-5548"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0002-1118-1738"/>
        <terms:contributor rdf:resource="https://orcid.org/0009-0002-7282-0836"/>
        <terms:created>2025-06-14T22:20:08Z</terms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/PHASES_0002010"/>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/PHASES_0002012"/>
        <rdfs:label xml:lang="en">performative identity quality</rdfs:label>
        <skos:definition xml:lang="en">A personal identity quality formed as a result of the agent&apos;s performative behaviors as influencing and influenced by the formation of one&apos;s psychological identity.</skos:definition>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PHASES_0000011 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PHASES_0000011">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/MF_0000033"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-6906-5548"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0002-1118-1738"/>
        <terms:contributor rdf:resource="https://orcid.org/0009-0002-7282-0836"/>
        <terms:created>2025-06-14T22:20:08Z</terms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/PHASES_0002012"/>
        <rdfs:label xml:lang="en">social withdrawal disposition</rdfs:label>
        <skos:definition xml:lang="en">A mental disposition that, if realized, is realized in the consistent avoidance of social interactions with both familiar and unfamiliar peers due to psychological traits such as social fear or anxiety.</skos:definition>
        <skos:prefLabel>social withdrawal</skos:prefLabel>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PHASES_0000012 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PHASES_0000012">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/phases.owl/PHASES_0000050"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-6906-5548"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0002-1118-1738"/>
        <terms:contributor rdf:resource="https://orcid.org/0009-0002-7282-0836"/>
        <terms:created>2025-06-14T22:20:08Z</terms:created>
        <terms:description>Self-transcendence is a concept relevant to understanding how human beings attain or maintain well-being.</terms:description>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/PHASES_0002010"/>
        <rdfs:label xml:lang="en">self-transcendence disposition</rdfs:label>
        <skos:definition xml:lang="en">A transcendence disposition that, if realized, is realized in shifting one’s focus beyond the self toward broader existential, moral, or spiritual concerns, including care for others, connection with nature, or alignment with perceived universal values.</skos:definition>
        <skos:prefLabel>self-transcendence</skos:prefLabel>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/PHASES_0000012"/>
        <owl:annotatedProperty rdf:resource="http://purl.org/dc/terms/description"/>
        <owl:annotatedTarget>Self-transcendence is a concept relevant to understanding how human beings attain or maintain well-being.</owl:annotatedTarget>
        <terms:source>https://www.ncbi.nlm.nih.gov/books/NBK585654/</terms:source>
    </owl:Axiom>
    


    <!-- http://purl.obolibrary.org/obo/PHASES_0000021 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PHASES_0000021">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/MF_0000033"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-6906-5548"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0002-1118-1738"/>
        <terms:contributor rdf:resource="https://orcid.org/0009-0002-7282-0836"/>
        <terms:created>2025-06-14T22:20:08Z</terms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/PHASES_0002012"/>
        <rdfs:label xml:lang="en">elective solitude disposition</rdfs:label>
        <skos:definition xml:lang="en">A mental disposition that, if realized, is realized in intentionally withdrawing from social interaction in order to pursue self-reflection, restoration, or personal goals.</skos:definition>
        <skos:prefLabel>elective solitude</skos:prefLabel>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PHASES_0000022 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PHASES_0000022">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000020"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-6906-5548"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0002-1118-1738"/>
        <terms:contributor rdf:resource="https://orcid.org/0009-0002-7282-0836"/>
        <terms:created>2025-06-14T22:20:08Z</terms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/PHASES_0002012"/>
        <rdfs:label xml:lang="en">imposed solitude characteristic</rdfs:label>
        <skos:definition xml:lang="en">A characteristic of a person that is physically or socially alone due to external constraints or circumstances, and not by personal choice.</skos:definition>
        <skos:prefLabel>imposed solitude</skos:prefLabel>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PHASES_0000023 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PHASES_0000023">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/MF_0000033"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-6906-5548"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0002-1118-1738"/>
        <terms:contributor rdf:resource="https://orcid.org/0009-0002-7282-0836"/>
        <terms:created>2025-06-14T22:20:08Z</terms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/PHASES_0002012"/>
        <rdfs:label xml:lang="en">ambient sociability disposition</rdfs:label>
        <skos:definition xml:lang="en">A mental disposition that is realized in retaining the sense of social presence without direct social engagement with others in a public or semi-public space.</skos:definition>
        <skos:prefLabel>ambient sociability</skos:prefLabel>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PHASES_0000024 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PHASES_0000024">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/GO_0008150"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-6906-5548"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0002-1118-1738"/>
        <terms:contributor rdf:resource="https://orcid.org/0009-0002-7282-0836"/>
        <terms:created>2025-06-14T22:20:08Z</terms:created>
        <terms:description>Healthy aging is the process of preserving and enhancing one’s independence, physical and mental well-being, and overall quality of life. It involves the mental, emotional, and cognitive wellness.</terms:description>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/PHASES_0002010"/>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/PHASES_0002012"/>
        <rdfs:label xml:lang="en">healthy aging process</rdfs:label>
        <skos:definition xml:lang="en">A biological process that is realized in maintaining functional ability, emotional well-being, and social engagement in later life, relative to cultural and personal expectations.</skos:definition>
        <skos:prefLabel>healthy aging</skos:prefLabel>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/PHASES_0000024"/>
        <owl:annotatedProperty rdf:resource="http://purl.org/dc/terms/description"/>
        <owl:annotatedTarget>Healthy aging is the process of preserving and enhancing one’s independence, physical and mental well-being, and overall quality of life. It involves the mental, emotional, and cognitive wellness.</owl:annotatedTarget>
        <terms:source>Basu, Tanisha &amp; Sehar, Ujala &amp; Malhotra, Keya &amp; Culberson, John &amp; Khan, Hafiz &amp; Morton, Hallie &amp; Orlov, Erika &amp; Brownell, Malcolm &amp; Reddy, P. Hemachandra. (2023). Healthy Brain Aging and Delayed Dementia in Texas Rural Elderly. Ageing Research Reviews. 91. 102047. 10.1016/j.arr.2023.102047</terms:source>
    </owl:Axiom>
    


    <!-- http://purl.obolibrary.org/obo/PHASES_0000025 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PHASES_0000025">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PHASES_0000008"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-6906-5548"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0002-1118-1738"/>
        <terms:contributor rdf:resource="https://orcid.org/0009-0002-7282-0836"/>
        <terms:created>2025-06-14T22:20:08Z</terms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/PHASES_0002010"/>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/PHASES_0002012"/>
        <rdfs:label xml:lang="en">successful aging construct information content entity</rdfs:label>
        <skos:definition xml:lang="en">A psychological construct information content entity that describes achieving physical health, cognitive vitality, and continued involvement with life, as measured against individual and cultural standards of aging well.</skos:definition>
        <skos:prefLabel>successful aging construct</skos:prefLabel>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PHASES_0000026 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PHASES_0000026">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/MF_0000033"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-6906-5548"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0002-1118-1738"/>
        <terms:contributor rdf:resource="https://orcid.org/0009-0002-7282-0836"/>
        <terms:created>2025-06-14T22:20:08Z</terms:created>
        <terms:description>Aloneliness is conceptualized as the negative feelings that arise from the perception that one is not spending enough time alone.</terms:description>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/PHASES_0002012"/>
        <rdfs:label xml:lang="en">aloneliness disposition</rdfs:label>
        <skos:definition xml:lang="en">A mental disposition that, if realized, is realized in experiencing discomfort or distress due to a perceived lack of desired time alone.</skos:definition>
        <skos:prefLabel>aloneliness</skos:prefLabel>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PHASES_0000027 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PHASES_0000027">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/MF_0000033"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-6906-5548"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0002-1118-1738"/>
        <terms:contributor rdf:resource="https://orcid.org/0009-0002-7282-0836"/>
        <terms:created>2025-06-14T22:20:08Z</terms:created>
        <terms:description>When a person socialy withdrawls, he or she retreats from interpersonal relationships, usually accompanied by an attitude of indifference, detachment, and aloofness. Social withdrawal is often associated with disorders such as schizophrenia, autism spectrum disorder, and depression.</terms:description>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/PHASES_0002012"/>
        <rdfs:label xml:lang="en">social detachment disposition</rdfs:label>
        <skos:definition xml:lang="en">A mental disposition that, if realized, is realized in reduced motivation to engage in or maintain social relationships, often without distress or social fear.</skos:definition>
        <skos:prefLabel>social detachment</skos:prefLabel>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PHASES_0000028 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PHASES_0000028">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/MF_0000033"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-6906-5548"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0002-1118-1738"/>
        <terms:contributor rdf:resource="https://orcid.org/0009-0002-7282-0836"/>
        <terms:created>2025-06-14T22:20:08Z</terms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/PHASES_0002012"/>
        <rdfs:label xml:lang="en">shyness behavior disposition</rdfs:label>
        <skos:definition xml:lang="en">A mental disposition to social anxiety that, if realized, is realized in the inhibition of behavior during potential social interaction due to fear of negative evaluation.</skos:definition>
        <skos:prefLabel>shyness</skos:prefLabel>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PHASES_0000029 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PHASES_0000029">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/MF_0000033"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-6906-5548"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0002-1118-1738"/>
        <terms:contributor rdf:resource="https://orcid.org/0009-0002-7282-0836"/>
        <terms:created>2025-06-14T22:20:08Z</terms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/PHASES_0002012"/>
        <rdfs:label xml:lang="en">solitude affinity disposition</rdfs:label>
        <skos:definition xml:lang="en">A mental disposition that, if realized, is realized in seeking out and enjoying time spent alone for reflection, creativity, or restoration.</skos:definition>
        <skos:prefLabel>solitude affinity</skos:prefLabel>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PHASES_0000030 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PHASES_0000030">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
        <obo:IAO_0000115 xml:lang="en">A quality that concretizes some information content entity.</obo:IAO_0000115>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-6906-5548"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0002-1118-1738"/>
        <terms:contributor rdf:resource="https://orcid.org/0009-0002-7282-0836"/>
        <terms:created>2025-06-14T22:20:08Z</terms:created>
        <terms:description>A quality that represents something information content entity, made up of different parts arranged in a certain way to form a whole, and is a characteristic of something, whether it’s physical or abstract.</terms:description>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/PHASES_0002010"/>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/PHASES_0002012"/>
        <rdfs:label xml:lang="en">representational pattern quality</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PHASES_0000031 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PHASES_0000031">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PHASES_0000032"/>
        <obo:IAO_0000115>A mental representational pattern quality that has mind-to-world direction of fit.</obo:IAO_0000115>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-6906-5548"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0002-1118-1738"/>
        <terms:contributor rdf:resource="https://orcid.org/0009-0002-7282-0836"/>
        <terms:created>2025-06-14T22:20:08Z</terms:created>
        <terms:description>A mental representation that represents an information content entity, made up of different parts arranged in a specific way to form a whole, and is a characteristic of something, physical or abstract, invovling skills involved in tasks related to perception, learning, memory, understanding, awareness, reasoning, judgment, intuition, and language.</terms:description>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/PHASES_0002010"/>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/PHASES_0002012"/>
        <rdfs:label xml:lang="en">cognitive representational pattern quality</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PHASES_0000032 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PHASES_0000032">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PHASES_0000030"/>
        <obo:IAO_0000115 xml:lang="en">A representational pattern quality that specifically depends on the cognitive system of its bearer.</obo:IAO_0000115>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-6906-5548"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0002-1118-1738"/>
        <terms:contributor rdf:resource="https://orcid.org/0009-0002-7282-0836"/>
        <terms:created>2025-06-14T22:20:08Z</terms:created>
        <terms:description>A hypothetical entity representing a perception, thought, memory, or something similar during mental processes, made up of separate parts arranged in a way that forms a whole, and being a characteristic of something, whether physical or abstract.</terms:description>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/PHASES_0002010"/>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/PHASES_0002012"/>
        <rdfs:label xml:lang="en">mental representational pattern quality</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PHASES_0000036 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PHASES_0000036">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/MF_0000075"/>
        <obo:IAO_0000115 xml:lang="en">A mental quality that is defined by (a) a set of physical, psychological, and interpersonal characteristics that is not wholly shared with any other person and (b) a range of affiliations (e.g., ethnicity) and social roles.</obo:IAO_0000115>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-6906-5548"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0002-1118-1738"/>
        <terms:contributor rdf:resource="https://orcid.org/0009-0002-7282-0836"/>
        <terms:created>2025-06-14T22:20:08Z</terms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/PHASES_0002010"/>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/PHASES_0002012"/>
        <rdfs:label xml:lang="en">personal identity quality</rdfs:label>
        <skos:altLabel xml:lang="en">self-concept</skos:altLabel>
        <skos:prefLabel>personal identity</skos:prefLabel>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PHASES_0000038 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PHASES_0000038">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PHASES_0000036"/>
        <obo:IAO_0000115 xml:lang="en">A personal identity quality consisting of the internalized, evolving, story of oneself that individuals construct to make sense and meaning out of life.</obo:IAO_0000115>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-6906-5548"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0002-1118-1738"/>
        <terms:contributor rdf:resource="https://orcid.org/0009-0002-7282-0836"/>
        <terms:created>2025-06-14T22:20:08Z</terms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/PHASES_0002010"/>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/PHASES_0002012"/>
        <rdfs:label xml:lang="en">narrative identity quality</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PHASES_0000039 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PHASES_0000039">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PHASES_0000036"/>
        <obo:IAO_0000115 xml:lang="en">A personal identity quality consisting of the recognition of oneself as a persisting entity, resulting from the integration of one&apos;s ego-ideal, life roles, and adjustments to reality.</obo:IAO_0000115>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-6906-5548"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0002-1118-1738"/>
        <terms:contributor rdf:resource="https://orcid.org/0009-0002-7282-0836"/>
        <terms:created>2025-06-14T22:20:08Z</terms:created>
        <terms:description>Ego identity may also be understood as an adaptive accomplishment or achievement of the individual vis-a-vis his social environment. Specifically, it is the adaptation of the individual&apos;s special skills, capacities, and strengths to the prevailing role structure of the society in which he lives.</terms:description>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/PHASES_0002010"/>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/PHASES_0002012"/>
        <rdfs:label xml:lang="en">ego identity quality</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/PHASES_0000039"/>
        <owl:annotatedProperty rdf:resource="http://purl.org/dc/terms/description"/>
        <owl:annotatedTarget>Ego identity may also be understood as an adaptive accomplishment or achievement of the individual vis-a-vis his social environment. Specifically, it is the adaptation of the individual&apos;s special skills, capacities, and strengths to the prevailing role structure of the society in which he lives.</owl:annotatedTarget>
        <terms:source>Bourne E. The state of research on ego identity: A review and appraisal : Part I. J Youth Adolesc. 1978 Sep;7(3):223-51. doi: 10.1007/BF01537976. PMID: 24408808</terms:source>
    </owl:Axiom>
    


    <!-- http://purl.obolibrary.org/obo/PHASES_0000042 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PHASES_0000042">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PHASES_0000008"/>
        <obo:IAO_0000115 xml:lang="en">A psychological construct that is putatively about biologically-based dispositions to avoid others due to social fears and anxieties</obo:IAO_0000115>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-6906-5548"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0002-1118-1738"/>
        <terms:contributor rdf:resource="https://orcid.org/0009-0002-7282-0836"/>
        <terms:created>2025-06-14T22:20:08Z</terms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/PHASES_0002012"/>
        <rdfs:comment xml:lang="en">How are behavioral inhibition and anxious-solitude related to and distinct from solitude? (anxious-solitude, and behavioral inhibition are all constructs reflecting biologically-based dispositions to avoid others due to social fears and anxieties)</rdfs:comment>
        <rdfs:label xml:lang="en">anxious solitude construct information content entity</rdfs:label>
        <skos:prefLabel>anxious solitude construct</skos:prefLabel>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/PHASES_0000046 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PHASES_0000046">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000033"/>
        <obo:IAO_0000115>A directive information content entity that prescribes any of various established rules, methods, procedures, and practices which have been accepted as guides for social conduct over a relatively long period.</obo:IAO_0000115>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-6906-5548"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0002-1118-1738"/>
        <terms:contributor rdf:resource="https://orcid.org/0009-0002-7282-0836"/>
        <terms:created>2025-06-14T22:20:08Z</terms:created>
        <terms:description>A process during which someone behaves according to established rules, methods, procedures, and practices that have been accepted as guides for social conduct over a relatively long period.</terms:description>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/PHASES_0002010"/>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/PHASES_0002012"/>
        <rdfs:label xml:lang="en">social convention directive information entity</rdfs:label>
        <skos:definition>Everyone conforms to R
Everyone believes others conform to R
This belief gives everyone a good reason to conform to R himself 
Everyone believes others are doing the best they can to conform to R
R is not the only possible regularity meeting (3) and (4)
Each of the preceding factors are in principle common knowledge</skos:definition>
        <skos:prefLabel>social convention</skos:prefLabel>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/PHASES_0000046"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>A directive information content entity that prescribes any of various established rules, methods, procedures, and practices which have been accepted as guides for social conduct over a relatively long period.</owl:annotatedTarget>
        <obo:IAO_0000119>https://dictionary.apa.org/social-convention</obo:IAO_0000119>
    </owl:Axiom>
    


    <!-- http://purl.obolibrary.org/obo/PHASES_0002000 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PHASES_0002000">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/MF_0000033"/>
        <obo:IAO_0000115>A mental disposition that, if realized, is realized in being physical alone or in lacking social interactions, whether desired or not.</obo:IAO_0000115>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-6906-5548"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0002-1118-1738"/>
        <terms:contributor rdf:resource="https://orcid.org/0009-0002-7282-0836"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-02-05T17:49:47+00:00</terms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/PHASES_0002012"/>
        <rdfs:comment xml:lang="en">Solitude is most often linked to low levels of loneliness and positive emotions when it is chosen solitude (due to enjoying solitude) and spent in active ways; people with a propensity to ruminate and those who choose solitude because they do not like being with others tend to suffer the most in solitude - Julie</rdfs:comment>
        <rdfs:comment xml:lang="en">What are the different motivations that explain why some seek solitude? Here there are so many overlapping terms (ie., unsociability, preference for solitude, avoidance, social anhedonia, affinity for solitude, affinity for aloneness, aversion to aloneness, autonomous solitude, not self-motivated solitude), but I have a recent study suggesting that the constructs tend to load into three larger factors: shyness, affinity for solitude, and social detachment.</rdfs:comment>
        <rdfs:label>solitude behavior disposition</rdfs:label>
        <skos:prefLabel xml:lang="en">solitude</skos:prefLabel>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/PHASES_0002000"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>A mental disposition that, if realized, is realized in being physical alone or in lacking social interactions, whether desired or not.</owl:annotatedTarget>
        <obo:IAO_0000119>Oliveira, J., Guerra, S., Sousa, L., &amp; Ribeiro, O. (2024). Solitude in old age: a scoping review of conceptualisations, associated factors and impacts. Aging &amp; Mental Health, 29(2), 220–227. https://doi.org/10.1080/13607863.2024.2379408</obo:IAO_0000119>
    </owl:Axiom>
    


    <!-- http://purl.obolibrary.org/obo/PHASES_0002001 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PHASES_0002001">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/MF_0000033"/>
        <obo:IAO_0000115>A mental disposition borne by older adults such that, if realized, is realized in shifting in goals, values, and perspectives towards connections to past and future generations and in seeking coherence in one&apos;s life narrative.</obo:IAO_0000115>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-6906-5548"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0002-1118-1738"/>
        <terms:contributor rdf:resource="https://orcid.org/0009-0002-7282-0836"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-02-05T17:54:30Z</terms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/PHASES_0002010"/>
        <rdfs:label xml:lang="en">gerotranscendence disposition</rdfs:label>
        <skos:prefLabel>gerotranscendence</skos:prefLabel>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/PHASES_0002001"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>A mental disposition borne by older adults such that, if realized, is realized in shifting in goals, values, and perspectives towards connections to past and future generations and in seeking coherence in one&apos;s life narrative.</owl:annotatedTarget>
        <obo:IAO_0000119>https://pmc.ncbi.nlm.nih.gov/articles/PMC10466938/</obo:IAO_0000119>
    </owl:Axiom>
    


    <!-- http://purl.obolibrary.org/obo/PHASES_0002002 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PHASES_0002002">
        <rdfs:subClassOf rdf:resource="http://humanbehaviourchange.org/ontology/BCIO_006014"/>
        <obo:IAO_0000115>Social alienation that, if realized, is realized in being physically alone and desiring not to be.</obo:IAO_0000115>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-6906-5548"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0002-1118-1738"/>
        <terms:contributor rdf:resource="https://orcid.org/0009-0002-7282-0836"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-02-26T21:16:23+00:00</terms:created>
        <terms:description>Social isolation ranges from the voluntary withdrawal from social interaction, where an individual chooses to disengage for personal or situational reasons to involuntary isolation, where separation from others is imposed externally or occurs against th eindividual&apos;s will.</terms:description>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/PHASES_0002012"/>
        <rdfs:label xml:lang="en">social isolation behavior disposition</rdfs:label>
        <skos:prefLabel>social isolation</skos:prefLabel>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/PHASES_0002002"/>
        <owl:annotatedProperty rdf:resource="http://purl.org/dc/terms/description"/>
        <owl:annotatedTarget>Social isolation ranges from the voluntary withdrawal from social interaction, where an individual chooses to disengage for personal or situational reasons to involuntary isolation, where separation from others is imposed externally or occurs against th eindividual&apos;s will.</owl:annotatedTarget>
        <terms:source>Biordi, D. L., &amp; Nicholson, N. R. (2013). Social isolation. Chronic illness: Impact and intervention, 97-132.</terms:source>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/PHASES_0002002"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>Social alienation that, if realized, is realized in being physically alone and desiring not to be.</owl:annotatedTarget>
        <obo:IAO_0000119>https://www.nia.nih.gov/health/loneliness-and-social-isolation/loneliness-and-social-isolation-tips-staying-connected</obo:IAO_0000119>
    </owl:Axiom>
    


    <!-- http://purl.obolibrary.org/obo/PHASES_0002003 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PHASES_0002003">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/MFOEM_000006"/>
        <obo:IAO_0000115>A subjective affective feeling of dissatisfaction with a lack of social interactions and relationships.</obo:IAO_0000115>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-6906-5548"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
        <terms:contributor rdf:resource="https://orcid.org/0009-0002-7282-0836"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-02-05T17:58:33+00:00</terms:created>
        <terms:description>Feeling of loneliness is a subjective and often distressing emotional state that arises from a perceived discrepancy between an individual’s desired and actual social relationships. It encompasses feelings of emptiness, abandonment, or disconnection, can develop over time, and is influenced by personal, social, and situational factors including identity, expectations, life events, and socio-economic conditions.</terms:description>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/PHASES_0002012"/>
        <rdfs:label xml:lang="en">feeling of loneliness</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/PHASES_0002003"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>A subjective affective feeling of dissatisfaction with a lack of social interactions and relationships.</owl:annotatedTarget>
        <obo:IAO_0000119>Asher, S. R., Hymel, S., &amp; Renshaw, P. D. (1984). Loneliness in children. Child development, 1456-1464.</obo:IAO_0000119>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/PHASES_0002003"/>
        <owl:annotatedProperty rdf:resource="http://purl.org/dc/terms/description"/>
        <owl:annotatedTarget>Feeling of loneliness is a subjective and often distressing emotional state that arises from a perceived discrepancy between an individual’s desired and actual social relationships. It encompasses feelings of emptiness, abandonment, or disconnection, can develop over time, and is influenced by personal, social, and situational factors including identity, expectations, life events, and socio-economic conditions.</owl:annotatedTarget>
        <terms:source>Yanguas J, Pinazo-Henandis S, Tarazona-Santabalbina FJ. The complexity of loneliness. Acta Biomed. 2018 Jun 7;89(2):302-314. doi:10.23750/abm.v89i2.7404. PMID: 29957768; PMCID: PMC6179015.</terms:source>
    </owl:Axiom>
    


