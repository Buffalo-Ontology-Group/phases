     xmlns:oboInOwl="http://www.geneontology.org/formats/oboInOwl#">
    <owl:Ontology rdf:about="http://purl.obolibrary.org/obo/phases/phases-base.owl">
        <owl:versionIRI rdf:resource="http://purl.obolibrary.org/obo/phases/releases/2026-02-25/phases-base.owl"/>
        <dc:type rdf:resource="http://purl.obolibrary.org/obo/IAO_8000001"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-6906-5548"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-9189-9661"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0002-1118-1738"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0002-2999-0103"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0003-2294-3571"/>
        <terms:contributor rdf:resource="https://orcid.org/0009-0002-7282-0836"/>
        <terms:contributor rdf:resource="https://orcid.org/0009-0009-9778-4641"/>
        <terms:description>PHASES provides an ontology for integrating research in solitude and gerotranscendence. By integrating these areas of study, we aim to deepen our understanding of each and how they promote healthy aging.</terms:description>
        <terms:license rdf:resource="https://creativecommons.org/publicdomain/zero/1.0/"/>
        <terms:title>Promoting Health Aging through Semantic Enrichment of Solitude Research (PHASES) Ontology</terms:title>
        <owl:versionInfo>2026-02-25</owl:versionInfo>
    </owl:Ontology>
    


