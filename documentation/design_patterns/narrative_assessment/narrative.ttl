@prefix ex: <http://example.org/ex/> .
@prefix obo: <http://purl.obolibrary.org/obo/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Psychologist a obo:MF_0000016,
        owl:NamedIndividual ;
    rdfs:label "Psychologist" ;
    obo:BFO_0000056 ex:Analysis .

ex:Self1 a obo:PHASES_0000006,
        owl:NamedIndividual ;
    rdfs:label "Self-appraisal quality" ;
    obo:BFO_0000195 ex:Narrative_Agent_1 ;
    obo:RO_0000059 ex:ICE_instance .

obo:BFO_0000016 a owl:Class ;
    rdfs:label "Disposition<br/>" .

ex:Analysis a obo:BFO_0000015,
        owl:NamedIndividual ;
    rdfs:label "Analysis procedure" ;
    obo:RO_0002234 ex:Narrative_Theme .

ex:Narrative_Agent_1 a obo:MF_0000016,
        owl:NamedIndividual ;
    rdfs:label "Subject 1" ;
    obo:BFO_0000056 ex:Narrative_Construction ;
    obo:BFO_0000185 ex:Agent_Life_1 .

ex:Narrative_Construction a obo:BFO_0000015,
        owl:NamedIndividual ;
    rdfs:label "Narrative construction" ;
    obo:RO_0002234 ex:ICE_instance .

ex:Narrative_Theme a obo:PHASES_0000008,
        owl:NamedIndividual ;
    rdfs:label "Narrative Theme Assessment" ;
    obo:IAO_0000136 ex:ICE_instance .

ex:Structure a obo:BFO_0000031,
        owl:NamedIndividual ;
    rdfs:label "Narrative Structure" .

obo:BFO_0000031 a owl:Class ;
    rdfs:label "Generically Dependent Continuant<br/>" .

obo:BFO_0000182 a owl:Class ;
    rdfs:label "History<br/>" .

obo:IAO_0000030 a owl:Class ;
    rdfs:label "Information Content Entity<br/>" .

obo:PHASES_0000006 a owl:Class ;
    rdfs:label "Self-appraisal representational pattern quality<br/>" .

obo:PHASES_0000008 a owl:Class ;
    rdfs:label "Psychological Construct ICE<br/>" .

ex:Agent_Life_1 a obo:BFO_0000182,
        owl:NamedIndividual ;
    rdfs:label "Agent Life 1" .

obo:BFO_0000015 a owl:Class ;
    rdfs:label "Process<br/>" .

obo:MF_0000016 a owl:Class ;
    rdfs:label "Human Being<br/>" .

ex:ICE_instance a obo:IAO_0000030,
        owl:NamedIndividual ;
    rdfs:label "Narrative" ;
    obo:BFO_0000178 ex:Structure ;
    obo:IAO_0000136 ex:Agent_Life_1 .

